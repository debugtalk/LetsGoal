{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/scripts/*"],
      "@directions/*": ["directions/*"]
    }
  },
  "include": [
    "core/**/*.ts",
    "directions/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "directions/*/fixtures/**"
  ]
}
